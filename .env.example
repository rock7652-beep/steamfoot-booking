# =============================================
# 蒸足店預約管理系統 - 環境變數
# 複製為 .env 並填入真實值
# =============================================

# 資料庫（Docker 本地開發）
DATABASE_URL="postgresql://steamfoot:steamfoot_dev@localhost:5432/steamfoot"
DIRECT_URL="postgresql://steamfoot:steamfoot_dev@localhost:5432/steamfoot"

# NextAuth
NEXTAUTH_SECRET="請改成至少32字元的隨機字串"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# Email SMTP（Phase 2 提醒用）
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-gmail@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="your-gmail@gmail.com"

# Cron 保護金鑰
CRON_SECRET="請改成一段隨機字串"
